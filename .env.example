# ─── Postgres ───────────────────────────────────────────────
POSTGRES_USER=learner
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=learning_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Backend ────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_64_byte_random_string
JWT_LIFETIME_SECONDS=3600
JWT_REFRESH_LIFETIME_SECONDS=2592000

# ─── OpenAI LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=50000

# ─── Demo seed user (auto-created on startup) ───────────────
DEMO_USERNAME=demo
DEMO_PASSWORD=learnnow

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=LearnAnything

# ─── Production (Coolify) ───────────────────────────────────
# Set these in Coolify's environment variable UI rather than committing them.
# DOMAIN=learn.example.com
# ACME_EMAIL=you@example.com
